{
  "manifest_version": 3,
  "name": "Footy Scores",
  "version": "0.2.1",
  "description": "Live football scores in your browser side panel",
  "permissions": ["sidePanel"],
  "action": {
    "default_title": "Footy Scores",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
